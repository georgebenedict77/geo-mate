# App server
PORT=3050
APP_NAME=GEO MATE
NODE_ENV=development
DATA_DIR=./data

# Dev only: expose OTPs in API responses
SHOW_DEV_CODES=false

# Email OTP provider: resend or sendgrid
EMAIL_PROVIDER=
EMAIL_FROM=verified@yourdomain.com
RESEND_API_KEY=
SENDGRID_API_KEY=

# SMS OTP provider: twilio
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX